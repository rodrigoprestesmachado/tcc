\ProvidesPackage{square}[2025/07/06 Pacote para Quadros ABNT]

\RequirePackage{array, booktabs}

\newcounter{quadros}
\renewcommand{\thequadros}{\arabic{quadros}}

\newcommand{\squarecaption}[1]{%
  \ifdefined\ABNTEXfontereduzida
    {\ABNTEXfontereduzida
     Quadro~\thequadros\ABNTEXcaptiondelim#1}%
  \else
    {\footnotesize Quadro~\thequadros~--~#1}%
  \fi
}

% Legenda centralizada acima do conteúdo (mesmo padrão de figuras/tabelas).
% Centralize apenas a tabela com \centering no corpo do ambiente.
% O conteúdo fica em uma minipage para não quebrar entre páginas.
\newenvironment{square}[1][]{%
  \refstepcounter{quadros}%
  \par\addvspace{\baselineskip}%
  \noindent\begin{minipage}{\linewidth}%
  {\centering\squarecaption{#1}\par}%
  \addvspace{0.5\baselineskip}%
}{%
  \end{minipage}%
  \par\addvspace{\baselineskip}%
}

\endinput
